# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Telegram user id администраторов (кому доступны /export и /stats), через запятую.
# Свой id можно узнать у @userinfobot
ADMIN_IDS=111111111,222222222

# Путь к файлу БД (необязательно; по умолчанию — рядом с bot.py)
# DB_PATH=/var/lib/feedback-bot/feedback.db

# Час (UTC) ежедневной авто-выгрузки. По умолчанию 6 = 09:00 МСК.
# DAILY_EXPORT_HOUR_UTC=6
